# Copy this file to .env and fill in real values.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
DOWNLOAD_DIR=/tmp/tg-downloads
DOWNLOAD_TIMEOUT=120

# Inline mode — ID канала/чата куда бот загружает медиа для получения file_id.
# Создай приватный канал, добавь бота админом, узнай ID через @userinfobot.
# BUFFER_CHAT_ID=-1001234567890

# Instagram auth (вариант 1 — логин/пароль, gallery-dl авторизуется сам)
# INSTAGRAM_USER=your_username
# INSTAGRAM_PASS=your_password

# Instagram auth (вариант 2 — cookies файл, экспортированный из браузера)
# См. cookies/README.md
COOKIES_FILE=cookies/instagram.txt
